{
  "name": "aiagent-hub",
  "private": true,
  "version": "0.0.0",
  "description": "Полевой справочник автономной разработки с Claude Code: 3 299 портативных промтов, 76 комбо, 30 шпаргалок, 108 CLI-команд.",
  "homepage": "https://ai-agent-hub.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/AJKSLEGION123/AIAgent-Hub.git"
  },
  "bugs": {
    "url": "https://github.com/AJKSLEGION123/AIAgent-Hub/issues"
  },
  "license": "MIT",
  "author": "Pavel <pavelte382@gmail.com>",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "ai-prompts",
    "prompt-engineering",
    "llm",
    "developer-tools",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "bin": {
    "aiagent-hub": "./cli/index.cjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:all": "vitest run && npx playwright test",
    "knip": "knip",
    "check-i18n": "node scripts/check-i18n.cjs",
    "check": "npm run lint && npm run typecheck && npm run knip && node scripts/check-data.cjs && npm run check-i18n && npm test && npm run build",
    "api": "node api/server.cjs",
    "dev:all": "concurrently \"npm run dev\" \"npm run api\""
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "hono": "^4.12.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^2.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.7.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "vite": "^8.0.10"
  }
}
