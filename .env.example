# AIAgent-Hub — Environment Variables
#
# Production (Vercel) needs NONE — the live SPA is fully client-side.
# Variables below are only for the development artifacts in api/ and bot/
# (they're not deployed; see SECURITY.md "Scope" section).
#
# Copy this file to .env (gitignored) and edit as needed.

# ──────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────

# Override dev server port (default 5173)
# VITE_PORT=5173

# ──────────────────────────────────────────────
# Local API server (api/server.cjs)
# Used by `npm run api` or `npm run dev:all`
# ──────────────────────────────────────────────

# HTTP port for the local Hono API (default 3001 — referenced in src/test/api.test.js)
# PORT=3001

# ──────────────────────────────────────────────
# Telegram bot (bot/telegram.cjs)
# Used only if you wire up the optional Telegram integration
# ──────────────────────────────────────────────

# Bot token from @BotFather. Required to start the bot.
# TELEGRAM_BOT_TOKEN=

# ──────────────────────────────────────────────
# Self-hosted deploy (scripts/ssh-deploy-docker.py)
# Used only if you maintain a self-hosted mirror via Cloudflare Tunnel
# ──────────────────────────────────────────────

# SSH credentials for the deploy target. Most users won't need this.
# DEPLOY_HOST=
# DEPLOY_USER=
# DEPLOY_KEY_PATH=
