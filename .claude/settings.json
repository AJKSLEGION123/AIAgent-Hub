{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "Project-level Claude Code settings. Applies to every session opened in this repo. See CLAUDE.md for the full AUTONOMY-v4 policy.",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch(*)",
      "WebSearch(*)",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git remote*)",
      "Bash(git fetch*)",
      "Bash(git stash*)",
      "Bash(git add*)",
      "Bash(git restore*)",
      "Bash(git checkout*)",
      "Bash(git commit*)",
      "Bash(git push origin *)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git tag*)",
      "Bash(git reset HEAD*)",
      "Bash(git rm --cached*)",

      "Bash(npm install*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm ls*)",
      "Bash(npm outdated*)",
      "Bash(npm audit*)",
      "Bash(npm ci)",
      "Bash(npx *)",

      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",

      "Bash(node *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(pwd)",
      "Bash(ls*)",
      "Bash(cd *)",
      "Bash(dir*)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(rm *)",
      "Bash(echo *)",
      "Bash(sleep *)",
      "Bash(date*)",
      "Bash(env)",
      "Bash(printenv*)",

      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(uv *)",
      "Bash(pip *)",
      "Bash(pytest*)",
      "Bash(ruff*)",
      "Bash(mypy*)",

      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(rustc *)",

      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(kubectl *)",
      "Bash(helm *)",

      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ping *)",
      "Bash(nslookup *)",
      "Bash(dig *)",
      "Bash(tasklist*)",
      "Bash(ps *)",
      "Bash(top)",
      "Bash(htop)",

      "Bash(cat *)",
      "Bash(jq *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(find *)",
      "Bash(awk *)",
      "Bash(sed *)",

      "Bash(gh *)",

      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",

      "mcp__claude-in-chrome__*",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__*",
      "mcp__plugin_playwright_playwright__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_vercel_vercel__*",
      "mcp__plugin_github_github__*",
      "mcp__plugin_linear_linear__*",
      "mcp__plugin_sentry_sentry__*",
      "mcp__plugin_figma_figma__*",
      "mcp__plugin_prisma_*",
      "mcp__plugin_supabase_supabase__*",
      "mcp__plugin_stripe_stripe__*",
      "mcp__plugin_slack_slack__*",
      "mcp__plugin_postman_postman__*",
      "mcp__plugin_microsoft-docs_microsoft-learn__*",
      "mcp__filesystem__*",
      "mcp__memory__*",
      "mcp__magic__*",
      "mcp__sequential-thinking__*",
      "mcp__postgres__*"
    ],
    "deny": [
      "Bash(* --no-verify *)",
      "Bash(git push *--force*)",
      "Bash(git push *-f *)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(chmod 777 *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_TOOL_INPUT\" in *'--no-verify'*|*'--force'*|*'-f '*) echo '\u26a0  Destructive flag detected' >&2;; esac"
          }
        ]
      }
    ]
  }
}
